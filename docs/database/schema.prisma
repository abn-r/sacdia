  @@unique([club_enrollment_id, month, year])
  @@index([club_enrollment_id], map: "idx_monthly_reports_enrollment")
  @@index([status], map: "idx_monthly_reports_status")
}

model monthly_report_manual_data {
  manual_data_id                 String   @id @default(dbgenerated("extensions.uuid_generate_v4()")) @db.Uuid
  monthly_report_id              String   @unique @db.Uuid
  planning_meetings              Int      @default(0)
  parent_meetings                Int      @default(0)
  youth_council_attendance       Int      @default(0)
  church_board_attendance        Int      @default(0)
  soul_target                    Int      @default(0)
  unbaptized_members             Int      @default(0)
  bible_studies_receiving        Int      @default(0)
  has_weekly_bible_instruction   Boolean  @default(false)
  bible_studies_given            Boolean  @default(false)
  literature_distributed         Boolean  @default(false)
  baptized_this_month            Int      @default(0)
  total_baptized                 Int      @default(0)
  club_participation_description String?
  community_service_description  String?
  certificates_delivered         Boolean  @default(false)
  members_have_booklet           Boolean  @default(false)
  booklet_requirements_signed    Boolean  @default(false)
  created_at                     DateTime @default(now()) @db.Timestamptz(6)
  modified_at                    DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  monthly_report monthly_reports @relation(fields: [monthly_report_id], references: [monthly_report_id], onDelete: Cascade, onUpdate: NoAction)

  @@index([monthly_report_id], map: "idx_monthly_report_manual_data_report")
}

// ========================================
// TRANSFER & ASSIGNMENT REQUESTS (Phase 7)
// ========================================

model club_transfer_requests {
  transfer_request_id String    @id @default(dbgenerated("extensions.uuid_generate_v4()")) @db.Uuid
  user_id             String    @db.Uuid
  from_section_id     Int
  to_section_id       Int
  reason              String?
  status              String    @default("pending")
  reviewed_by         String?   @db.Uuid
  review_comment      String?
  reviewed_at         DateTime?
  created_at          DateTime  @default(now()) @db.Timestamptz(6)
  modified_at         DateTime  @default(now()) @updatedAt @db.Timestamptz(6)

  user         users         @relation("transfer_requester", fields: [user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction)
  from_section club_sections @relation("transfer_from", fields: [from_section_id], references: [club_section_id], onDelete: NoAction, onUpdate: NoAction)
  to_section   club_sections @relation("transfer_to", fields: [to_section_id], references: [club_section_id], onDelete: NoAction, onUpdate: NoAction)
  reviewer     users?        @relation("transfer_reviewer", fields: [reviewed_by], references: [user_id], onDelete: NoAction, onUpdate: NoAction)

  @@index([user_id], map: "idx_transfer_requests_user")
  @@index([from_section_id], map: "idx_transfer_requests_from_section")
  @@index([to_section_id], map: "idx_transfer_requests_to_section")
  @@index([status], map: "idx_transfer_requests_status")
}

model role_assignment_requests {
  request_id      String    @id @default(dbgenerated("extensions.uuid_generate_v4()")) @db.Uuid
  club_section_id Int
  user_id         String    @db.Uuid
  role_id         String    @db.Uuid
  requested_by    String    @db.Uuid
  status          String    @default("pending")
  approved_by     String?   @db.Uuid
  comment         String?
  reviewed_at     DateTime?
  created_at      DateTime  @default(now()) @db.Timestamptz(6)
  modified_at     DateTime  @default(now()) @updatedAt @db.Timestamptz(6)

  club_section club_sections @relation(fields: [club_section_id], references: [club_section_id], onDelete: NoAction, onUpdate: NoAction)
  user         users         @relation("assignment_target", fields: [user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction)
  role         roles         @relation(fields: [role_id], references: [role_id], onDelete: NoAction, onUpdate: NoAction)
  requester    users         @relation("assignment_requester", fields: [requested_by], references: [user_id], onDelete: NoAction, onUpdate: NoAction)
  approver     users?        @relation("assignment_approver", fields: [approved_by], references: [user_id], onDelete: NoAction, onUpdate: NoAction)

  @@index([club_section_id], map: "idx_assignment_requests_section")
  @@index([user_id], map: "idx_assignment_requests_user")
  @@index([role_id], map: "idx_assignment_requests_role")
  @@index([status], map: "idx_assignment_requests_status")
}

// ========================================
// VALIDATION LOGS (Generic audit trail)
// ========================================

model validation_logs {
  validation_log_id String   @id @default(dbgenerated("extensions.uuid_generate_v4()")) @db.Uuid
  entity_type       String   @db.VarChar(20)
  entity_id         String   @db.VarChar(50)
  user_id           String   @db.Uuid
  action            String   @db.VarChar(20)
  performed_by      String   @db.Uuid
  comment           String?
  created_at        DateTime @default(now()) @db.Timestamptz()

  user      users @relation("validation_log_user", fields: [user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction)
  performer users @relation("validation_log_performer", fields: [performed_by], references: [user_id], onDelete: NoAction, onUpdate: NoAction)

  @@index([entity_type, entity_id])
  @@index([user_id])
}

// ========================================
// RESOURCES MODULE
// ========================================

model resource_categories {
  resource_category_id Int         @id @default(autoincrement())
  name                 String      @unique @db.VarChar(100)
  description          String?
  active               Boolean     @default(true)
  created_at           DateTime    @default(now()) @db.Timestamptz(6)
  modified_at          DateTime    @default(now()) @updatedAt @db.Timestamptz(6)
  resources            resources[]

  @@index([active], map: "idx_resource_categories_active")
}

model resources {
  resource_id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title                String   @db.VarChar(255)
  description          String?
  resource_type        String   @db.VarChar(20)
  resource_category_id Int?
  club_type_id         Int?
  scope_level          String   @db.VarChar(20)
  scope_id             Int?
  file_key             String?  @db.VarChar(500)
  file_name            String?  @db.VarChar(255)
  file_size            Int?
  file_mime_type       String?  @db.VarChar(100)
  content              String?
  external_url         String?  @db.VarChar(1000)
  uploaded_by          String   @db.Uuid
  active               Boolean  @default(true)
  created_at           DateTime @default(now()) @db.Timestamptz(6)
  modified_at          DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  resource_categories resource_categories? @relation(fields: [resource_category_id], references: [resource_category_id], onDelete: SetNull, onUpdate: NoAction)
  club_types          club_types?          @relation(fields: [club_type_id], references: [club_type_id], onDelete: SetNull, onUpdate: NoAction)
  users               users                @relation(fields: [uploaded_by], references: [user_id], onDelete: Cascade, onUpdate: NoAction)

  @@index([active], map: "idx_resources_active")
  @@index([scope_level, scope_id], map: "idx_resources_scope")
  @@index([club_type_id], map: "idx_resources_club_type")
  @@index([resource_category_id], map: "idx_resources_category")
  @@index([resource_type], map: "idx_resources_type")
}

// ─── Achievement System ────────────────────────────────────────────

enum achievement_type {
  THRESHOLD
  STREAK
  COMPOUND
  MILESTONE
  COLLECTION
}

enum achievement_scope {
  GLOBAL
  CLUB_TYPE
  ECCLESIASTICAL_YEAR
}

enum achievement_tier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
  DIAMOND
}

model achievement_categories {
  achievement_category_id Int            @id @default(autoincrement())
  name                    String         @unique @db.VarChar(100)
  description             String?        @db.VarChar(500)
  icon                    String?        @db.VarChar(100)
  display_order           Int            @default(0)
  active                  Boolean        @default(true)
  created_at              DateTime       @default(now()) @db.Timestamptz(6)
  modified_at             DateTime       @default(now()) @updatedAt @db.Timestamptz(6)
  achievements            achievements[]

  @@map("achievement_categories")
}

model achievements {
  achievement_id  Int               @id @default(autoincrement())
  category_id     Int
  name            String            @unique @db.VarChar(200)
  description     String            @db.VarChar(1000)
  badge_image_key String?           @db.VarChar(500)
  type            achievement_type
  scope           achievement_scope @default(GLOBAL)
  tier            achievement_tier  @default(BRONZE)
  points          Int               @default(0)
  criteria        Json
  secret          Boolean           @default(false)
  repeatable      Boolean           @default(false)
  max_repeats     Int?
  club_type_id    Int?
  prerequisite_id Int?
  active          Boolean           @default(true)
  created_at      DateTime          @default(now()) @db.Timestamptz(6)
  modified_at     DateTime          @default(now()) @updatedAt @db.Timestamptz(6)

  category          achievement_categories @relation(fields: [category_id], references: [achievement_category_id], onDelete: NoAction, onUpdate: NoAction)
  club_type         club_types?            @relation(fields: [club_type_id], references: [club_type_id], onDelete: NoAction, onUpdate: NoAction)
  prerequisite      achievements?          @relation("achievement_chain", fields: [prerequisite_id], references: [achievement_id], onDelete: NoAction, onUpdate: NoAction)
  dependents        achievements[]         @relation("achievement_chain")
  user_achievements user_achievements[]

  @@index([category_id], map: "idx_achievements_category")
  @@index([type], map: "idx_achievements_type")
  @@index([scope, club_type_id], map: "idx_achievements_scope_club")
  @@index([active], map: "idx_achievements_active")
  @@map("achievements")
}

model user_achievements {
  user_achievement_id    Int       @id @default(autoincrement())
  user_id                String    @db.Uuid
  achievement_id         Int
  progress_value         Int       @default(0)
  progress_target        Int
  progress_metadata      Json?
  completed              Boolean   @default(false)
  completed_at           DateTime? @db.Timestamptz(6)
  notified               Boolean   @default(false)
  ecclesiastical_year_id Int?
  times_completed        Int       @default(0)
  active                 Boolean   @default(true)
  created_at             DateTime  @default(now()) @db.Timestamptz(6)
  modified_at            DateTime  @default(now()) @updatedAt @db.Timestamptz(6)

  users               users                 @relation(fields: [user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction)
  achievement         achievements          @relation(fields: [achievement_id], references: [achievement_id], onDelete: NoAction, onUpdate: NoAction)
  ecclesiastical_year ecclesiastical_years? @relation(fields: [ecclesiastical_year_id], references: [year_id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([user_id, achievement_id, ecclesiastical_year_id])
  @@index([user_id, completed], map: "idx_user_achievements_user_completed")
  @@index([achievement_id], map: "idx_user_achievements_achievement")
  @@index([user_id, achievement_id], map: "idx_user_achievements_user_achievement")
  @@map("user_achievements")
}

model achievement_event_log {
  event_id      Int      @id @default(autoincrement())
  user_id       String   @db.Uuid
  event_type    String   @db.VarChar(100)
  event_payload Json
  processed     Boolean  @default(false)
  created_at    DateTime @default(now()) @db.Timestamptz(6)

  users users @relation(fields: [user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction)

  @@index([user_id, event_type, created_at], map: "idx_achievement_events_user_type_date")
  @@index([processed, created_at], map: "idx_achievement_events_processed")
  @@map("achievement_event_log")
}
