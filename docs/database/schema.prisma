model folder_templates {
  folder_template_id     String    @id @default(dbgenerated("extensions.uuid_generate_v4()")) @db.Uuid
  name                   String    @db.VarChar(200)
  club_type_id           Int
  ecclesiastical_year_id Int
  active                 Boolean   @default(true)
  minimum_points         Int       @default(0)
  closing_date           DateTime? @db.Timestamptz(6)
  created_at             DateTime  @default(now()) @db.Timestamptz(6)
  modified_at            DateTime  @default(now()) @updatedAt @db.Timestamptz(6)

  club_type           club_types                 @relation(fields: [club_type_id], references: [club_type_id], onDelete: NoAction, onUpdate: NoAction)
  ecclesiastical_year ecclesiastical_years       @relation(fields: [ecclesiastical_year_id], references: [year_id], onDelete: NoAction, onUpdate: NoAction)
  sections            folder_template_sections[]
  annual_folders      annual_folders[]

  @@unique([club_type_id, ecclesiastical_year_id])
  @@index([club_type_id], map: "idx_folder_templates_club_type")
  @@index([ecclesiastical_year_id], map: "idx_folder_templates_year")
}

model folder_template_sections {
  section_id         String   @id @default(dbgenerated("extensions.uuid_generate_v4()")) @db.Uuid
