  max_points         Int      @default(0)
  minimum_points     Int      @default(0)
  created_at         DateTime @default(now()) @db.Timestamptz(6)
  modified_at        DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  folder_template    folder_templates                    @relation(fields: [folder_template_id], references: [folder_template_id], onDelete: Cascade, onUpdate: NoAction)
  evidences          annual_folder_evidences[]
  evaluations        annual_folder_section_evaluations[]
  section_submissions annual_folder_section_submissions[]

  @@index([folder_template_id], map: "idx_folder_template_sections_template")
}

model annual_folders {
  annual_folder_id    String    @id @default(dbgenerated("extensions.uuid_generate_v4()")) @db.Uuid
  club_enrollment_id  String    @db.Uuid
  folder_template_id  String    @db.Uuid
  /// Status values: "open", "submitted", "under_evaluation", "evaluated", "closed"
  status              String    @default("open") @db.VarChar(20)
  submitted_at        DateTime? @db.Timestamptz(6)
  closed_at           DateTime? @db.Timestamptz(6)
  total_earned_points Int       @default(0)
  total_max_points    Int       @default(0)
  progress_percentage Float     @default(0)
  evaluated_at        DateTime? @db.Timestamptz(6)
  created_at          DateTime  @default(now()) @db.Timestamptz(6)
  modified_at         DateTime  @default(now()) @updatedAt @db.Timestamptz(6)

  club_enrollment     club_enrollments                    @relation(fields: [club_enrollment_id], references: [club_enrollment_id], onDelete: NoAction, onUpdate: NoAction)
  folder_template     folder_templates                    @relation(fields: [folder_template_id], references: [folder_template_id], onDelete: NoAction, onUpdate: NoAction)
  evidences           annual_folder_evidences[]
  evaluations         annual_folder_section_evaluations[]
  section_submissions annual_folder_section_submissions[]

  @@unique([club_enrollment_id])
  @@index([folder_template_id], map: "idx_annual_folders_template")
}

model annual_folder_evidences {
  evidence_id      String   @id @default(dbgenerated("extensions.uuid_generate_v4()")) @db.Uuid
  annual_folder_id String   @db.Uuid
  section_id       String   @db.Uuid
  file_url         String
  file_name        String   @db.VarChar(255)
  uploaded_by      String   @db.Uuid
  notes            String?
  created_at       DateTime @default(now()) @db.Timestamptz(6)
  modified_at      DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  annual_folder annual_folders           @relation(fields: [annual_folder_id], references: [annual_folder_id], onDelete: Cascade, onUpdate: NoAction)
  section       folder_template_sections @relation(fields: [section_id], references: [section_id], onDelete: NoAction, onUpdate: NoAction)
